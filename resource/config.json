		},
		{
			"name": "local-ager",
			"sql": "select split_part(agable_scn_gap,'.',3) from v$agable_info",
			"tag": "sql2"
		},
		{
			"name": "stmt",
			"sql": "select count(*) from v$statement",
			"tag": "sql2"
		},
		{
			"name": "disk-/home",
			"sql": "df -h |grep /home |awk '{print $5}' |grep -o '[0-9]'*",
			"tag": "sql1",
			"isOs": true
		},
		{
			"name": "MemAvaimb",
			"diff": false,
			"alertValue": 80,
			"alertPolicy": 1,
